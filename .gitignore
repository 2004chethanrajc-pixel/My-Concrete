# Root .gitignore for the entire project

# Backend specific
backend/node_modules/
backend/.env
backend/uploads/
backend/*.log
backend/build/
backend/dist/

# Frontend specific (if you have a React Native or web frontend)
frontend/node_modules/
frontend/.env
frontend/.env.local
frontend/build/
frontend/dist/
frontend/.expo/
frontend/web-build/

# Mobile specific
*.apk
*.ipa
*.app

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
*.log
logs/

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
tmp/
temp/
*.tmp

# Database files
*.sqlite
*.sqlite3
*.db

# SSL certificates
*.pem
*.key
*.crt

# Backup files
*.backup
*.bak